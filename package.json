{
  "name": "@echo/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "core:start": "npx nx serve core",
    "redis:init": "docker run -d --name echo-redis -p 6379:6379 redis:alpine",
    "supabase:start": "npx supabase start",
    "supabase:sync": "npx supabase db diff -f init_schema",
    "supabase:apply": "npx supabase db reset",
    "supabase:types": "npx supabase gen types typescript --local > libs/shared/supabase-client/src/lib/database.types.ts",
    "prepare": "husky install"
  },
  "private": true,
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@mendable/firecrawl-js": "^4.16.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@supabase/supabase-js": "^2.99.1",
    "axios": "^1.6.0",
    "bullmq": "^5.71.0",
    "handlebars": "^4.7.8",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/docker": "22.5.4",
    "@nx/eslint": "22.5.4",
    "@nx/eslint-plugin": "22.5.4",
    "@nx/js": "22.5.4",
    "@nx/nest": "22.5.4",
    "@nx/node": "22.5.4",
    "@nx/web": "22.5.4",
    "@nx/webpack": "22.5.4",
    "@nx/workspace": "22.5.4",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/node": "20.19.9",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^8.0.0",
    "jsonc-eslint-parser": "^2.1.0",
    "nx": "22.5.4",
    "prettier": "~3.6.2",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "webpack-cli": "^5.1.4"
  },
  "workspaces": [
    "apps/*",
    "libs/shared/*"
  ],
  "lint-staged": {
    "*.{js,ts,tsx,mts}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
